# 服务器配置
PORT=3000
HOST=0.0.0.0

# 开发模式配置
USE_MOCK=true

# SQL Server配置（危急值系统本地库）
SQL_SERVER_HOST=localhost
SQL_SERVER_PORT=1433
SQL_SERVER_DATABASE=CriticalValueSystem
SQL_SERVER_USER=sa
SQL_SERVER_PASSWORD=your_password
SQL_SERVER_ENCRYPT=false
SQL_SERVER_TRUST_CERT=true

# Oracle配置（HIS系统）
ORACLE_HOST=196.57.57.242
ORACLE_PORT=1521
ORACLE_SERVICE=halodb
ORACLE_USER=his3interface
ORACLE_PASSWORD=his3interface

# 企业微信配置
WECHAT_CORP_ID=your_corp_id
WECHAT_CORP_SECRET=your_corp_secret
WECHAT_AGENT_ID=1000001

# 轮询配置（毫秒）
POLLING_INTERVAL=30000
WRITEBACK_INTERVAL=30000
ESCALATION_INTERVAL=900000

# 日志配置
LOG_LEVEL=info
